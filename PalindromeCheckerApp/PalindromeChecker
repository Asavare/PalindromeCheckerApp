import java.util.Scanner;
import java.util.Stack;

public class UseCase13PalindromeCheckerApp {

    // Method 1: Reverse String Approach
    public static boolean isPalindromeReverse(String input) {
        String cleaned = input.replaceAll("[^a-zA-Z0-9]", "").toLowerCase();
        String reversed = new StringBuilder(cleaned).reverse().toString();
        return cleaned.equals(reversed);
    }

    // Method 2: Two Pointer Approach
    public static boolean isPalindromeTwoPointer(String input) {
        String cleaned = input.replaceAll("[^a-zA-Z0-9]", "").toLowerCase();
        int left = 0;
        int right = cleaned.length() - 1;

        while (left < right) {
            if (cleaned.charAt(left) != cleaned.charAt(right)) {
                return false;
            }
            left++;
            right--;
        }
        return true;
    }

    // Method 3: Stack Approach
    public static boolean isPalindromeStack(String input) {
        String cleaned = input.replaceAll("[^a-zA-Z0-9]", "").toLowerCase();
        Stack<Character> stack = new Stack<>();

        for (char c : cleaned.toCharArray()) {
            stack.push(c);
        }

        for (char c : cleaned.toCharArray()) {
            if (c != stack.pop()) {
                return false;
            }
        }
        return true;
    }

    public static void main(String[] args) {

        Scanner scanner = new Scanner(System.in);

        System.out.println("=== UC13: Performance Comparison of Palindrome Algorithms ===");
        System.out.print("Enter a string to check: ");
        String input = scanner.nextLine();

        // Method 1 Timing
        long start1 = System.nanoTime();
        boolean result1 = isPalindromeReverse(input);
        long end1 = System.nanoTime();
        long time1 = end1 - start1;

        // Method 2 Timing
        long start2 = System.nanoTime();
        boolean result2 = isPalindromeTwoPointer(input);
        long end2 = System.nanoTime();
        long time2 = end2 - start2;

        // Method 3 Timing
        long start3 = System.nanoTime();
        boolean result3 = isPalindromeStack(input);
        long end3 = System.nanoTime();
        long time3 = end3 - start3;

        // Display Results
        System.out.println("\n--- Results ---");
        System.out.println("Reverse Method Result      : " + result1);
        System.out.println("Two Pointer Method Result  : " + result2);
        System.out.println("Stack Method Result        : " + result3);

        System.out.println("\n--- Execution Time (nanoseconds) ---");
        System.out.println("Reverse Method      : " + time1);
        System.out.println("Two Pointer Method  : " + time2);
        System.out.println("Stack Method        : " + time3);

        scanner.close();
    }
}